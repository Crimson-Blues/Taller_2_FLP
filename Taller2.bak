#lang eopl
;; Gramática
; <literal> ::= <entero-no-cero>
; <or-exp> ::= <literal> | <literal> or <or-exp>
; <clausula> ::= ( <or-exp> )
; <and-exp> ::= <clausula> | <clausula> and <and-exp>
; <fnc-exp> ::= FNC <natural> ( <and-exp> )


;;;; Implementación Basada en Listas ;;;;

;;; Constructores

;; Constructor de OR (clausula)
(define or-exp
  (lambda (varlist)
    (list 'or-exp varlist)
     )
  )

;; Constructor de AND (lista de clausulas - or-exp)
(define and-exp
  (lambda (clausulas)
    (list 'and-exp clausulas)
    )
  )

;; Constructor de fnc
; var : número natural
; and-exp : estrctura and 
(define fnc-exp
  (lambda (var and-exp)
    (list 'FNC var and-exp)
    )
  )

;;; Predicados

(define fnc-exp?
  (lambda (exp)
    (and (list? exp)
         (not (null? exp))
         (eqv? (car exp) 'FNC))))

(define or-exp?
  (lambda (exp)
    (and (list? exp)
         (not (null? exp))
         (eqv? (car exp) 'or-exp))))

(define and-exp?
  (lambda (exp)
    (and (list? exp)         
         (not (null? exp))   
         (eqv? (car exp) 'and-exp))))


;;; Extractores

;; Variables de la fnc
(define fnc->var
  (lambda (exp)
    (cadr exp)))

;; Clausulas de la fnc
(define fnc->clausulas
  (lambda (exp)
  (caddr exp)))

;; Variables de una clausula OR
(define or->varlist
  (lambda (clausula)
    (cadr clausula)))


;; Variables de una lista de clausulas AND
(define and->clausulas
  (lambda (and-exp)
    (cadr and-exp)))

;;; Definición de Instancias

;; Instancia 1 - FNC 2 ((1 or 2) and (-1) and (-2))
(define instancia-1
  (fnc-exp 2
           (and-exp (list (or-exp '(1 2)) (or-exp '(-1)) (or-exp '(-2)) ))
           )
  )

;; Instancia 2 - FNC 4 (1 or -2 or 3 or 4) and (-2 or 3) and (-1 or -2 or -3) and (3 or 4) and (2))
(define instancia-2
  (fnc-exp 4
           (and-exp (list (or-exp '(1 -2 3 4)) (or-exp '(-2 3)) (or-exp '(-1 -2 -3)) (or-exp '(3 4)) (or-exp '(2)) ))
           )
  )

;; Instancia 3 - FNC 3 ((3 or -1) and (-3) and (-2))
(define instancia-3
  (fnc-exp 3
           (and-exp (list (or-exp '(3 -1)) (or-exp '(-3)) (or-exp '(-2))))
           )
  )


;;; Ejemplos

;; Probando predicados (innecesario pero quería ajajja)
(fnc-exp? instancia-1)
(fnc-exp? instancia-2)
(fnc-exp? instancia-3)

;; Probando extractires
(fnc->var instancia-1)
(fnc->var instancia-3)
(fnc->clausulas instancia-2)
(or->varlist (or-exp '(1 -2 3)))
(or->varlist (car (and->clausulas (fnc->clausulas instancia-1))))




